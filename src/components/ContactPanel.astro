---
import { getLocaleFromUrl, getSiteConfig } from '../config/site';

const siteConfig = getSiteConfig(getLocaleFromUrl(Astro.url));
---

<section class="mx-auto max-w-6xl px-5 py-20">
	<div class="rounded-lg border border-white/10 bg-white/[0.04] p-8 md:p-10">
		<p class="text-sm font-medium uppercase tracking-[0.24em] text-zinc-500">{siteConfig.contactPanel.kicker}</p>
		<h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-normal text-white md:text-5xl">
			{siteConfig.contactPanel.heading}
		</h2>
		<div class="mt-8 flex flex-wrap gap-3">
			<a
				href={`mailto:${siteConfig.email}`}
				class="rounded-full bg-white px-5 py-3 text-sm font-medium text-black transition hover:bg-zinc-200"
			>
				{siteConfig.email}
			</a>
			{siteConfig.socials.map((item) => (
				<a
					href={item.href}
					target="_blank"
					class="inline-flex items-center gap-2 rounded-full border border-white/15 px-5 py-3 text-sm font-medium text-white transition hover:border-white/40 hover:bg-white/10"
				>
					<span class="grid h-6 w-6 place-items-center rounded-full bg-white/10 text-[10px] font-semibold">{item.icon}</span>
					{item.label}
				</a>
			))}
		</div>
	</div>
</section>

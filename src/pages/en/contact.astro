---
import Layout from '../../layouts/Layout.astro';
import ContactPanel from '../../components/ContactPanel.astro';
import { getLocaleFromUrl, getSiteConfig } from '../../config/site';

const siteConfig = getSiteConfig(getLocaleFromUrl(Astro.url));
const page = siteConfig.pages.contact;
---

<Layout title={page.title} description={page.description}>
	<section class="mx-auto max-w-6xl px-5 py-20 md:py-28">
		<p class="text-sm font-medium uppercase tracking-[0.28em] text-zinc-500">{page.kicker}</p>
		<h1 class="mt-6 max-w-4xl text-5xl font-semibold tracking-normal text-white md:text-7xl">{page.heading}</h1>
		<p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-400">{page.intro}</p>
		<div class="mt-10 grid gap-4 md:grid-cols-3">
			<a href={`mailto:${siteConfig.email}`} class="rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:border-white/30">
				<p class="text-sm text-zinc-500">Email</p>
				<p class="mt-3 break-words text-lg font-semibold text-white">{siteConfig.email}</p>
			</a>
			{siteConfig.socials.slice(0, 2).map((item) => (
				<a href={item.href} target="_blank" class="rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:border-white/30">
					<p class="text-sm text-zinc-500">{item.label}</p>
					<p class="mt-3 text-lg font-semibold text-white">{siteConfig.ui.socialCardCta}</p>
				</a>
			))}
		</div>
	</section>
	<ContactPanel />
</Layout>

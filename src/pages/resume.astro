---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactPanel from '../components/ContactPanel.astro';
import { getLocaleFromUrl, getSiteConfig } from '../config/site';

const siteConfig = getSiteConfig(getLocaleFromUrl(Astro.url));
const page = siteConfig.pages.resume;
---

<Layout title={page.title} description={page.description}>
	<section class="mx-auto max-w-6xl px-5 py-20 md:py-28">
		<SectionHeading
			kicker={page.kicker}
			title={page.heading}
			description={page.intro}
		/>
		<div class="grid gap-10 md:grid-cols-[0.35fr_0.65fr]">
			<aside class="space-y-8">
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-zinc-500">{page.locationLabel}</p>
					<p class="mt-2 text-white">{siteConfig.location}</p>
				</div>
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-zinc-500">{page.emailLabel}</p>
					<a href={`mailto:${siteConfig.email}`} class="mt-2 block text-white">{siteConfig.email}</a>
				</div>
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-zinc-500">{page.skillsLabel}</p>
					<div class="mt-3 flex flex-wrap gap-2">
						{siteConfig.skills.map((skill) => (
							<span class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-300">{skill}</span>
						))}
					</div>
				</div>
			</aside>
			<div class="space-y-4">
				{siteConfig.experience.map((item) => (
					<div class="rounded-lg border border-white/10 bg-white/[0.03] p-6">
						<p class="text-sm text-zinc-500">{item.period}</p>
						<h2 class="mt-3 text-2xl font-semibold text-white">{item.role}</h2>
						<p class="mt-1 text-sm text-zinc-400">{item.company}</p>
						<p class="mt-4 text-sm leading-6 text-zinc-400">{item.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<ContactPanel />
</Layout>
